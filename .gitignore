# .gitignore

# ── Secrets / Auth ────────────────────────────────────────────────────────────
token.json
credentials.json
client_secret_*.json
.env

# ── Python ────────────────────────────────────────────────────────────────────
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ── Test & Coverage Artifacts ─────────────────────────────────────────────────
test-results.xml
coverage.xml
.coverage
htmlcov/
.pytest_cache/

# ── Logs (generated by deployApp in script.groovy) ────────────────────────────
logs/*.log
!logs/.gitkeep

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp